<UserControl x:Class="umfg.venda.app.UserControls.ucReceberPedido"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:umfg.venda.app.UserControls"
             xmlns:conv="clr-namespace:umfg.venda.app.Converters"
             mc:Ignorable="d"
             d:DesignHeight="720" d:DesignWidth="1080">

    <UserControl.Resources>
        <!-- Formata DateTime? → "MM/yyyy" para exibição no TextBox do DatePicker -->
        <conv:MonthYearConverter x:Key="MonthYearConverter"/>
    </UserControl.Resources>

    <Viewbox Stretch="Uniform">
        <Grid Background="#ECF0F1" Height="720" Width="1080">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="70"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition MinWidth="500" MaxWidth="500"/>
            </Grid.ColumnDefinitions>

            <!-- ── Lista de produtos ─────────────────────────────────────────── -->
            <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal">
                <DataGrid ItemsSource="{Binding Pedido.Produtos}"
                          HeadersVisibility="None"
                          AutoGenerateColumns="False"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          GridLinesVisibility="None"
                          CanUserSortColumns="False">
                    <DataGrid.Resources>
                        <Style TargetType="DataGrid">
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="BorderBrush"     Value="#ECF0F1"/>
                            <Setter Property="Background"      Value="#ECF0F1"/>
                            <Setter Property="Foreground"      Value="Black"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="BorderBrush" Value="#E0E0E0"/>
                                    <Setter Property="Background"  Value="#E0E0E0"/>
                                    <Setter Property="Foreground"  Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTemplateColumn>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Ellipse Height="150" Width="150" HorizontalAlignment="Center">
                                        <Ellipse.Fill>
                                            <ImageBrush ImageSource="{Binding Imagem}"/>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Width="300">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Referencia}" FontWeight="SemiBold"
                                                   FontSize="24" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Descricao}"  FontWeight="SemiBold"
                                                   FontSize="24" VerticalAlignment="Center"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Width="115">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Vertical">
                                        <TextBlock Text="R$"           FontWeight="ExtraBold" FontSize="24" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Valor}" FontWeight="ExtraBold" FontSize="24" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>

            <!-- ── Formulário de pagamento ───────────────────────────────────── -->
            <StackPanel Grid.Row="0" Grid.Column="1"
                        Orientation="Vertical"
                        VerticalAlignment="Center"
                        Margin="16,0">

                <!-- Tipo do cartão -->
                <TextBlock Text="Tipo de Cartão" FontSize="20" FontWeight="SemiBold" Margin="0,8,0,2"/>
                <ComboBox FontSize="24" FontWeight="SemiBold"
                          SelectedIndex="{Binding TipoCartao, Mode=TwoWay}"
                          Width="468">
                    <ComboBoxItem Content="Selecione um Cartão"/>
                    <ComboBoxItem Content="Cartão de Crédito"/>
                    <ComboBoxItem Content="Cartão de Débito"/>
                </ComboBox>

                <!-- Número do cartão -->
                <TextBlock Text="Número do Cartão" FontSize="20" FontWeight="SemiBold" Margin="0,12,0,2"/>
                <TextBox Text="{Binding NumeroCartao, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="24" FontWeight="SemiBold" MaxLength="19"/>

                <!-- CVV -->
                <TextBlock Text="Código CVV (3 dígitos)" FontSize="20" FontWeight="SemiBold" Margin="0,12,0,2"/>
                <TextBox Text="{Binding CVV, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="24" FontWeight="SemiBold" MaxLength="3"/>

                <!-- Data de Validade — DatePicker restrito a Mês/Ano ───────────
                     Estratégia: DatePicker nativo com CalendarMode=Year.
                     Ao confirmar, o handler no code-behind ajusta o dia para 1.
                     O TextBox exibe apenas MM/yyyy via conversor.             -->
                <TextBlock Text="Validade (MM/yyyy)" FontSize="20" FontWeight="SemiBold" Margin="0,12,0,2"/>

                <DatePicker x:Name="dpValidade"
                            FontSize="24"
                            FontWeight="SemiBold"
                            SelectedDate="{Binding DataValidade, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            CalendarOpened="dpValidade_CalendarOpened"
                            SelectedDateChanged="dpValidade_SelectedDateChanged">
                    <DatePicker.Resources>
                        <!-- Formata o texto visível como MM/yyyy -->
                        <Style TargetType="DatePickerTextBox">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DatePickerTextBox">
                                        <TextBox x:Name="PART_TextBox"
                                                 Text="{Binding SelectedDate,
                                                        RelativeSource={RelativeSource AncestorType=DatePicker},
                                                        Converter={StaticResource MonthYearConverter}}"
                                                 FontSize="24"
                                                 FontWeight="SemiBold"
                                                 IsReadOnly="True"/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </DatePicker.Resources>
                </DatePicker>

                <!-- Nome no cartão -->
                <TextBlock Text="Nome no Cartão" FontSize="20" FontWeight="SemiBold" Margin="0,12,0,2"/>
                <TextBox Text="{Binding NomeCartao, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="24" FontWeight="SemiBold"/>

                <!-- Total do pedido -->
                <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                    <TextBlock Text="Total: R$ " FontSize="28" FontWeight="Bold"/>
                    <TextBlock Text="{Binding Pedido.Total, StringFormat=N2}"
                               FontSize="28" FontWeight="Bold"/>
                </StackPanel>
            </StackPanel>

            <!-- ── Botão Receber ─────────────────────────────────────────────── -->
            <StackPanel Grid.Row="1" Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,0,16,8">
                <Button Content="RECEBER"
                        FontSize="24"
                        FontWeight="Bold"
                        Padding="24,8"
                        Background="#27AE60"
                        Foreground="White"
                        BorderThickness="0"
                        Command="{Binding ReceberPedido}"
                        CommandParameter="{Binding}"/>
            </StackPanel>
        </Grid>
    </Viewbox>
</UserControl>